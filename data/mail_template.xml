<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <function model="ir.model.data" name="write">
            <value model="ir.model.data" search="[('module', '=', 'kio_invoice_email_template'), ('name', '=', 'email_template_samaa_invoice'), ('model', '=', 'mail.template')]"/>
            <value eval="{'name': 'mail_template_customer_invoice_samaa'}"/>
        </function>

        <record id="mail_template_customer_invoice_samaa" model="mail.template">
            <field name="name">Customer Invoice: Samaa Email</field>
            <field name="model_id" ref="account.model_account_move"/>
            <field name="subject">Invoice #{{ object.name or '' }} - Samaa Al Awir Vegetables &amp; Fruits Trading LLC</field>
            <field name="email_from">{{ (object.invoice_user_id.email_formatted or object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="description">Professional Samaa customer invoice email</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <t t-set="sale_orders" t-value="object.invoice_line_ids.sale_line_ids.order_id"/>
    <t t-set="sale_order_names" t-value="sale_orders.mapped('name')"/>
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Dear "<t t-out="object.partner_id.name or 'Customer'">Customer</t>",<br/><br/>

        I hope this email finds you well.<br/><br/>

        Please find attached Invoice #<strong><span t-out="object.name or ''">INV/2026/00001</span></strong>
        <t t-if="sale_order_names">
            (referencing Sales Order: <strong><span t-out="', '.join(sale_order_names)">SO00045</span></strong>)
        </t>
        amounting to <strong><span t-out="'%.2f' % object.amount_total">0.00</span></strong> AED from Samaa Al Awir Vegetables &amp; Fruits Trading LLC.<br/><br/>

        Kindly use <strong><span t-out="object.grn_reference or 'N/A'">N/A</span></strong> as the communication/reference for your payment.<br/><br/>

        Bank Details:<br/><br/>

        Bank Name: Emirates NBD<br/><br/>

        Account Name: SAMAA AL AWIR VEGETABLES &amp; FRUITS TRADING LLC<br/><br/>

        Account Number: 1015774412601<br/><br/>

        IBAN: AE39 0260 0010 1577 4412 601<br/><br/>

        SWIFT/BIC Code: EBILAEAD<br/><br/>

        Please note that if any objection/dispute is not raised within 7 days from receiving this invoice, we will assume everything is in order and approved.<br/><br/>

        Please remit payment at your earliest convenience and share the payment remittance advice once processed. Feel free to reach out if you have any questions.<br/><br/>

        Thank you for your business.<br/><br/>

        Best regards,<br/><br/>

        General Accountant
    </p>
</div>
            </field>
            <field name="report_template_ids" eval="[(4, ref('account.account_invoices'))]"/>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
